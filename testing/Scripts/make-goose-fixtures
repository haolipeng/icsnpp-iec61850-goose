#!/usr/bin/env python3
"""Generate derived GOOSE btest pcaps from the canonical GOOSE.pcap fixture."""

from pathlib import Path
import struct


ROOT = Path(__file__).resolve().parents[1]
TRACES = ROOT / "Traces"
SOURCE = TRACES / "GOOSE.pcap"


def read_first_packet(path):
    data = path.read_bytes()
    header = data[:24]
    endian = "<" if header[:4] in (b"\xd4\xc3\xb2\xa1", b"\x4d\x3c\xb2\xa1") else ">"
    ts_sec, ts_usec, incl_len, _orig_len = struct.unpack(endian + "IIII", data[24:40])
    packet = data[40:40 + incl_len]
    return header, endian, ts_sec, ts_usec, packet


def tlv_size(packet, offset):
    first_len = packet[offset + 1]
    if first_len & 0x80:
        len_octets = first_len & 0x7f
        value_len = int.from_bytes(packet[offset + 2:offset + 2 + len_octets], "big")
        return 2 + len_octets + value_len

    return 2 + first_len


def remove_goose_field(packet, tag):
    packet = bytearray(packet)
    goose_payload = 14
    goose_length = goose_payload + 2
    pdu_start = goose_payload + 8
    pdu_length = pdu_start + 2

    field_offset = packet.find(bytes([tag]), pdu_start)
    if field_offset < 0:
        raise RuntimeError(f"tag 0x{tag:02x} not found")

    removed = tlv_size(packet, field_offset)
    del packet[field_offset:field_offset + removed]

    packet[goose_length:goose_length + 2] = (int.from_bytes(packet[goose_length:goose_length + 2], "big") - removed).to_bytes(2, "big")
    packet[pdu_length] -= removed
    return bytes(packet)


def truncate_packet(packet, bytes_to_remove):
    return packet[:-bytes_to_remove]


def make_malformed_asn1(packet):
    packet = bytearray(packet)
    pdu_start = 14 + 8
    first_field_offset = pdu_start + 3

    # Replace the first context-specific field tag with BER high-tag-number
    # form. The parser does not implement high-tag-number decoding, so this is
    # malformed without making the packet short.
    packet[first_field_offset] = 0x1f
    return bytes(packet)


def write_one_packet(path, header, endian, ts_sec, ts_usec, packet):
    packet_header = struct.pack(endian + "IIII", ts_sec, ts_usec, len(packet), len(packet))
    path.write_bytes(header + packet_header + packet)


def main():
    header, endian, ts_sec, ts_usec, packet = read_first_packet(SOURCE)
    fixtures = {
        "GOOSE_missing_all_data.pcap": remove_goose_field(packet, 0xAB),
        "GOOSE_missing_gocb_ref.pcap": remove_goose_field(packet, 0x80),
        "GOOSE_truncated.pcap": truncate_packet(packet, 12),
        "GOOSE_malformed_asn1.pcap": make_malformed_asn1(packet),
    }

    for name, fixture in fixtures.items():
        write_one_packet(TRACES / name, header, endian, ts_sec, ts_usec, fixture)
        print(f"wrote {TRACES / name}")


if __name__ == "__main__":
    main()
